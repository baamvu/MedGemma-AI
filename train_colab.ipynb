      "source": [
        "import nltk\n",
        "from nltk.translate.bleu_score import sentence_bleu, SmoothingFunction\n",
        "from rouge_score import rouge_scorer\n",
        "from tqdm import tqdm\n",
        "\n",
        "nltk.download(\"punkt_tab\", quiet=True)\n",
        "import random\n",
        "EVAL_N = 80\n",
        "\n",
        "test_samples = []\n",
        "with open(f\"{PROCESSED_DIR}/test.jsonl\") as f:\n",
        "    for line in f:\n",
        "        if line.strip():\n",
        "            test_samples.append(json.loads(line))\n",
        "random.seed(42)\n",
        "if len(test_samples) > EVAL_N:\n",
        "    test_samples = random.sample(test_samples, EVAL_N)\n",
        "\n",
        "print(f\"Evaluating {len(test_samples)} test samples...\")\n",
        "model.eval()\n",
        "\n",
        "all_bleu = {f\"bleu_{i}\": [] for i in range(1, 5)}\n",
        "all_rouge = []\n",
        "smooth = SmoothingFunction().method1\n",
        "scorer = rouge_scorer.RougeScorer([\"rougeL\"], use_stemmer=True)\n",
        "\n",
        "for sample in tqdm(test_samples, desc=\"Evaluating\"):\n",
        "    ref = sample[\"report\"]\n",
        "    try:\n",
        "        image = Image.open(sample[\"image_path\"]).convert(\"RGB\")\n",
        "    except:\n",
        "        continue\n",
        "\n",
        "    msgs = [{\"role\": \"user\", \"content\": [\n",
        "        {\"type\": \"image\", \"image\": image},\n",
        "        {\"type\": \"text\", \"text\": PROMPT}]}]\n",
        "    text = processor.apply_chat_template(msgs, tokenize=False, add_generation_prompt=True)\n",
        "    inputs = processor(text=text, images=[image], return_tensors=\"pt\").to(model.device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        out = model.generate(**inputs, max_new_tokens=256, do_sample=False)\n",
        "    hyp = processor.tokenizer.decode(out[0, inputs[\"input_ids\"].shape[1]:], skip_special_tokens=True).strip()\n",
        "\n",
        "    ref_tok = nltk.word_tokenize(ref.lower())\n",
        "    hyp_tok = nltk.word_tokenize(hyp.lower())\n",
        "    if hyp_tok:\n",
        "        for n in range(1, 5):\n",
        "            w = tuple(1.0/n if i < n else 0.0 for i in range(4))\n",
        "            all_bleu[f\"bleu_{n}\"].append(sentence_bleu([ref_tok], hyp_tok, weights=w, smoothing_function=smooth))\n",
        "    all_rouge.append(scorer.score(ref, hyp)[\"rougeL\"].fmeasure)\n",
        "\n",
        "print(\"\\n\" + \"=\"*40)\n",
        "print(\"KET QUA DANH GIA\")\n",
        "print(\"=\"*40)\n",
        "for k, v in all_bleu.items():\n",
        "    print(f\"  {k}: {sum(v)/len(v):.4f}\")\n",
        "print(f\"  rouge_l: {sum(all_rouge)/len(all_rouge):.4f}\")\n",
        "print(\"=\"*40)"
      ]
    },
